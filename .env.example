# Kopieer naar .env voor lokaal testen. In productie worden deze waarden
# gezet via Dokploy compose environment variables (compose.update), NIET via dit bestand.

IMAGE_TAG=ghcr.io/klikwebmedia/pimcore-klikwebmedia:latest

MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=pimcore
MYSQL_USER=pimcore
MYSQL_PASSWORD=change-me

APP_SECRET=change-me

PIMCORE_ADMIN_USER=admin
PIMCORE_ADMIN_PASSWORD=change-me
